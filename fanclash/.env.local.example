# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Socket.IO (client-facing URL, e.g. Railway public URL)
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# Socket.IO server-to-server (internal URL, used by API routes)
SOCKET_SERVER_URL=http://localhost:3001
SOCKET_SERVER_SECRET=your_shared_secret

# Socket.IO server config (for server/.env or Railway env vars)
# PORT=3001
# CORS_ORIGIN=https://your-vercel-domain.vercel.app
